# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3005

# Frontend (Vite)
VITE_API_BASE_URL=/api
VITE_APP_NAME=Video Editor

# Uploads
MAX_UPLOAD_MB=500

# yt-dlp
YTDLP_MAX_DURATION_SEC=600
YTDLP_FORMAT=bestvideo[height<=720][ext=mp4]+bestaudio[ext=m4a]/best[height<=720][ext=mp4]/best[ext=mp4]/best
YTDLP_JS_RUNTIME=node
# Rate-limit to reduce bot detection
YTDLP_SLEEP_REQUESTS=0.25
YTDLP_SLEEP_INTERVAL=1
YTDLP_MAX_SLEEP_INTERVAL=3
YTDLP_TIMEOUT_MS=900000
# Dev-only: extract cookies from local browser (e.g. chrome or chrome:/path)
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Optional: enable verbose yt-dlp errors
# YTDLP_DEBUG=true
# Optional: cookies file to access age-restricted or bot-protected videos
# YTDLP_COOKIES=/app/cookies/ytdlp_cookies.txt

# FFmpeg export
FFMPEG_CRF=23
FFMPEG_PRESET=fast

# Subtitles (defaults)
SUBTITLE_DEFAULT_SIZE=22
SUBTITLE_DEFAULT_COLOR=#ffffff
SUBTITLE_DEFAULT_POSITION=bottom
VITE_SUBTITLE_DEFAULT_SIZE=22
VITE_SUBTITLE_DEFAULT_COLOR=#ffffff
VITE_SUBTITLE_DEFAULT_POSITION=bottom

# Whisper (auto subtitles) - openai-whisper (Python)
WHISPER_MODEL_DEFAULT=small
WHISPER_LANGUAGE_DEFAULT=auto
WHISPER_TIMEOUT_MS=1200000
WHISPER_PY_BIN=/opt/whisper-venv/bin/python
WHISPER_FASTER_DEVICE=cpu
WHISPER_FASTER_COMPUTE_TYPE=int8
